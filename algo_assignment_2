#include <stdio.h>
#include <stdlib.h>
struct Job
{
int id;
int deadline;
int profit;
int time;
};
void sortJobs(struct Job jobs[], int n)
{
for(int i=0;i<n-1;i++)
{
for(int j=i+1;j<n;j++)
{
if(jobs[i].profit < jobs[j].profit)
{
struct Job temp = jobs[i];
jobs[i] = jobs[j];
jobs[j] = temp;
}
}
}
}
int main()
{
int n,m;
FILE *fp;
printf("Enter number of jobs: ");
scanf("%d",&n);
struct Job jobs[n];
printf("Enter number of machines: ");
scanf("%d",&m);
printf("\nEnter job details (Deadline Profit ProcessingTime):\n");
for(int i=0;i<n;i++)
{
jobs[i].id = i+1;
scanf("%d %d %d",&jobs[i].deadline,&jobs[i].profit,&jobs[i].time);
}
sortJobs(jobs,n);
int slot[n];
for(int i=0;i<n;i++)
slot[i] = -1;
int totalProfit = 0;
for(int i=0;i<n;i++)
{
for(int j=jobs[i].deadline-1;j>=0;j--)
{
if(slot[j] == -1)
{
slot[j] = i;
totalProfit += jobs[i].profit;
break;
}
}
}
fp = fopen("job_scheduling_output.txt","w");
printf("\nJob List:\n");
printf("JobID\tDeadline\tProfit\tProcessingTime\n");
fprintf(fp,"\nJob List:\n");
fprintf(fp,"JobID\tDeadline\tProfit\tProcessingTime\n");
for(int i=0;i<n;i++)
{
printf("J%d\t%d\t\t%d\t%d\n",
jobs[i].id,jobs[i].deadline,jobs[i].profit,jobs[i].time);
fprintf(fp,"J%d\t%d\t\t%d\t%d\n",
jobs[i].id,jobs[i].deadline,jobs[i].profit,jobs[i].time);
}
printf("\nFinal Job Schedule:\n");
fprintf(fp,"\nFinal Job Schedule:\n");
for(int i=0;i<n;i++)
{
if(slot[i] != -1)
{
printf("Time Slot %d -> Job %d\n",i+1,jobs[slot[i]].id);
fprintf(fp,"Time Slot %d -> Job %d\n",i+1,jobs[slot[i]].id);
}
}
printf("\nTotal Profit = %d\n",totalProfit);
fprintf(fp,"\nTotal Profit = %d\n",totalProfit);
printf("\nAlgorithm Used: Greedy (Job Sequencing with Deadlines)\n");
printf("Time Complexity: O(n^2)\n");
fprintf(fp,"\nAlgorithm Used: Greedy (Job Sequencing with Deadlines)\n");
fprintf(fp,"Time Complexity: O(n^2)\n");
fclose(fp);
return 0;
}